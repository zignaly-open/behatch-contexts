{
    "name": "behatch/contexts",
    "description": "Behatch contexts",
    "keywords": ["BDD", "Behat", "Context"],
    "type": "library",
    "license": "beerware",

    "require": {
        "php": "^8.4",
        "behat/behat": "^3.15",
        "friends-of-behat/mink-extension": "^2.7",
        "justinrainbow/json-schema": "^6.5",
        "symfony/property-access": "^6.4.29",
        "symfony/http-foundation": "^6.4.29",
        "symfony/dom-crawler": "^6.4.29"
    },

    "require-dev": {
        "atoum/atoum": "^4.4",
        "behat/mink-browserkit-driver": "^2.3",
        "behat/mink-selenium2-driver": "^1.6",
        "guzzlehttp/guzzle": "^7.9",
        "symfony/browser-kit": "^6.4",
        "symfony/http-client": "^6.4",
        "rector/rector": "^2"
    },

    "autoload": {
        "psr-4": {
            "Behatch\\": "src/"
        }
    },

    "config": {
        "bin-dir": "bin/"
    },

    "replace": {
        "sanpi/behatch-contexts": "self.version"
    },

    "extra": {
        "branch-alias": {
            "dev-master": "5.0.x-dev"
        }
    }
}
